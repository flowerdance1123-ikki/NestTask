#!/bin/bash
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  情報共有シートDX — Platypus用起動スクリプト
#
#  このスクリプトは .app バンドル内から実行されることを想定。
#  read -p を使わないことが Platypus との互換性の条件。
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# ─── パス解決 ─────────────────────────────────────────────
# .appバンドル内 (Contents/Resources/) から実行される場合と
# 直接実行（開発テスト）される場合の両方に対応する
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"

if [[ "$SCRIPT_DIR" == *".app/Contents/Resources" ]]; then
  # .appバンドル内から実行されている場合
  # SCRIPT_DIR = /.../情報共有シートDX.app/Contents/Resources
  BUNDLE_DIR="$(cd "$SCRIPT_DIR/../.." && pwd)"
  ROOT_DIR="$(dirname "$BUNDLE_DIR")"          # .appの置かれているフォルダ
  SYSTEM_DIR="$SCRIPT_DIR/_システム用_触らない"  # バンドル内のシステムフォルダ
else
  # 直接実行（開発・テスト用）
  ROOT_DIR="$SCRIPT_DIR"
  SYSTEM_DIR="$ROOT_DIR/_システム用_触らない"
fi

VENV_DIR="$SYSTEM_DIR/.venv"

echo "起動準備中..."

# ─── システムフォルダの確認 ────────────────────────────────
if [ ! -d "$SYSTEM_DIR" ]; then
  echo "【エラー】アプリのファイルが見つかりません。野間までご連絡ください。"
  exit 1
fi

# ─── Python の確認 ─────────────────────────────────────────
if ! command -v python3 > /dev/null 2>&1; then
  echo "【エラー】Python3が見つかりません。https://www.python.org/downloads/macos/ からインストールしてください。"
  exit 1
fi

# ─── 仮想環境の確認・必要なら再構築 ────────────────────────
NEED_SETUP=false

if [ ! -f "$VENV_DIR/bin/python" ]; then
  NEED_SETUP=true
else
  if ! "$VENV_DIR/bin/python" -c "import fastapi, uvicorn, pypdf, reportlab, dotenv" 2>/dev/null; then
    NEED_SETUP=true
  fi
fi

if [ "$NEED_SETUP" = true ]; then
  echo "初期設定中（初回またはPC移行後）..."
  if [ -d "$VENV_DIR" ]; then
    mv "$VENV_DIR" "${VENV_DIR}_退避_$(date +%Y%m%d%H%M%S)"
  fi
  python3 -m venv "$VENV_DIR" || { echo "【エラー】環境の作成に失敗しました。野間までご連絡ください。"; exit 1; }
  "$VENV_DIR/bin/python" -m pip install --quiet --upgrade pip 2>/dev/null
  "$VENV_DIR/bin/python" -m pip install --quiet -r "$SYSTEM_DIR/requirements.txt" \
    || { echo "【エラー】インストールに失敗しました。インターネット接続を確認してください。"; exit 1; }
  echo "セットアップ完了！"
fi

# ─── 完成ファイルフォルダを確保 ────────────────────────────
# ROOT_DIR は .app の置かれているフォルダ → ユーザーがアクセスしやすい場所に作成
mkdir -p "$ROOT_DIR/完成ファイル"

# ─── 二重起動チェック ────────────────────────────────────
# ポートは起動ごとに動的に選択するため、プロセス名で既存インスタンスを検出する
EXISTING_PID=$(pgrep -f "webview_launcher.py" 2>/dev/null | head -1)
if [ -n "$EXISTING_PID" ]; then
  # 既に起動中 → SIGUSR1 でウィンドウを前面に出して終了
  kill -SIGUSR1 "$EXISTING_PID" 2>/dev/null
  exit 0
fi

echo "アプリを起動しています..."

# ─── 出力先を環境変数でFastAPIに伝える ────────────────────
export JOSHO_OUTPUT_DIR="$ROOT_DIR/完成ファイル"

# ─── 専用ウィンドウで起動 ─────────────────────────────────
cd "$SYSTEM_DIR"
"$VENV_DIR/bin/python" webview_launcher.py
